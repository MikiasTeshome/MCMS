# Server configuration
PORT=5000
NODE_ENV=development
API_VERSION=v1

# Database Configuration (for Prisma client)
DATABASE_URL="postgresql://postgres:postgres_password_123@localhost:5432/meal_coupon_db?schema=public"

# Authentication parameters
JWT_SECRET="your_super_secret_jwt_key_at_least_32_characters_long"
JWT_EXPIRE="24h"

# Allowed client URL
CLIENT_URL="http://localhost:5173"

# System defaults
DEFAULT_LANGUAGE="en"
RATE_LIMIT_MAX=100
