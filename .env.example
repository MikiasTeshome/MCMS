# ==============================================================================
# MEAL COUPON MANAGEMENT SYSTEM (MCMS) - GLOBAL ENVIRONMENT CONFIGURATION
# ==============================================================================

# --- DATABASE CONFIGURATION ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=meal_coupon_db
POSTGRES_PORT=5432

# Prisma database connection URL (Used by Prisma engine)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public

# --- BACKEND SERVER CONFIGURATION ---
PORT=5000
NODE_ENV=development
API_VERSION=v1

# JWT Configuration (for secure sessions)
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long
JWT_EXPIRE=24h

# CORS Configuration
CLIENT_URL=http://localhost:5173

# --- SYSTEM SETTINGS ---
# Default language (en, es, fr, etc.)
DEFAULT_LANGUAGE=en

# Rate limiting settings (request count per 15 minutes)
RATE_LIMIT_MAX=100

# --- FRONTEND ENVIRONMENT CONFIGURATION (VITE) ---
# Note: Vite client variables must be prefixed with VITE_ to be exposed to the client bundle
VITE_API_URL=http://localhost:5000/api/v1
VITE_DEFAULT_LANGUAGE=en
