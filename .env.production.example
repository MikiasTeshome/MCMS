# ==============================================================================
# MCMS - PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Instructions:
# 1. Copy this file to '.env' on your server: cp .env.production.example .env
# 2. Update the values with secure passwords, your domain name/IP, and secrets.
# 3. Both frontend and backend will load this file.

# --- DATABASE CONFIGURATION ---
# Note: These are used by PostgreSQL setup and Prisma.
POSTGRES_USER=mcms_admin
POSTGRES_PASSWORD=put_a_very_secure_random_password_here
POSTGRES_DB=meal_coupon_db
POSTGRES_PORT=5432

# Prisma Connection URL (points to your local PostgreSQL server)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public

# --- BACKEND SERVER CONFIGURATION ---
PORT=5000
NODE_ENV=production
API_VERSION=v1

# Security: JWT Secret (Generate a strong 32+ character random string)
# Example command to generate: openssl rand -base64 32
JWT_SECRET=replace_with_a_strong_random_jwt_secret_key_here

# Token Expiration (e.g. 24h)
JWT_EXPIRE=24h

# --- FRONTEND ENVIRONMENT CONFIGURATION (VITE) ---
# Vite variables must start with VITE_ to be compiled into the frontend bundle.
# Replace 'your-domain-or-ip.com' with the actual server IP or domain name.
VITE_API_URL=http://your-domain-or-ip.com/api/v1
VITE_DEFAULT_LANGUAGE=en

# CORS / Origin validation configuration
CLIENT_URL=http://your-domain-or-ip.com
DEFAULT_LANGUAGE=en

# Rate limiting request threshold per 15 minutes per IP
RATE_LIMIT_MAX=150
